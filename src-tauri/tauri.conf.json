{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aurelia",
  "version": "1.0.0",
  "identifier": "com.aurelia.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Aurelia",
        "width": 960,
        "height": 680,
        "minWidth": 600,
        "minHeight": 400,
        "transparent": false,
        "decorations": true,
        "hiddenTitle": true,
        "backgroundColor": [8, 12, 24, 255]
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; font-src 'self' data:; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {}
}
